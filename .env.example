# ── Git repositories ────────────────────────────────────────────────────────
# URL of your main DVC project repository (cloned into the container workspace)
# Leave empty if you manage the workspace yourself via a bind mount.
WORKSPACE_REPO=git@github.com:your-org/your-project.git

# Branch to track on both repos
GIT_BRANCH=main

# ── Sync ────────────────────────────────────────────────────────────────────
# How often (in seconds) to pull both repos inside the container
# 300 = every 5 minutes
SYNC_INTERVAL=300

# ── SSH / Git auth ───────────────────────────────────────────────────────────
# Path on the HOST to your SSH key directory.
# The container mounts this read-only so git can authenticate.
SSH_KEY_PATH=~/.ssh

# ── Git identity (used if the sync bot ever auto-commits) ────────────────────
GIT_AUTHOR_NAME=DVC Sync Bot
GIT_AUTHOR_EMAIL=dvc-sync@localhost
